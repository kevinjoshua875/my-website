@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>In between classes – School Bathroom</h1>

        <div class="video-wrapper">

            <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/ToiletingSkills/Screen1/0113 (14).mp4" type="video/mp4">
            </video>

            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Try to hold it in and wait until the next break
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Ask permission to the teacher and walk to the bathroom when you feel the urge
                    </button>
                </div>
            </div>

        </div>

        <button id="backBtn" class="back-btn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/ToiletingSkills/Screen1/0113 (14).mp4",
        correctVideo: "/ToiletingSkills/Screen1/0113 (15).mp4",
        wrongVideo: "/ToiletingSkills/Screen1/0113 (16).mp4",
        nextUrl: "/ToiletingSkills/Screen2"
    });
</script>
