@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>Leaving the Bathroom – Bathroom Door</h1>

        <div class="video-wrapper">

            <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/ToiletingSkills/Screen4/0113 (24).mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Forget to close the bathroom stall door properly
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Close the door fully behind you
                    </button>
                </div>
            </div>
        </div>

        <button id="backBtn" class="back-btn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/ToiletingSkills/Screen4/0113 (24).mp4",
        correctVideo: "/ToiletingSkills/Screen4/0113 (25).mp4",
        wrongVideo: "/ToiletingSkills/Screen4/0113 (26).mp4",
        nextUrl: "/ToiletingSkills/Screen5"
    });

</script>