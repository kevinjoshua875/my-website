@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>After Using the Toilet – Toilet Stall</h1>

        <div class="video-wrapper">

            <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/ToiletingSkills/Screen2/0113 (18).mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Forget to use toilet paper or use too little
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Use enough toilet paper to clean yourself properly
                    </button>
                </div>
            </div>
        </div>

        <button id="backBtn" class="back-btn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/ToiletingSkills/Screen2/0113 (18).mp4",
        correctVideo: "/ToiletingSkills/Screen2/0113 (19).mp4",
        wrongVideo: "/ToiletingSkills/Screen2/0113 (20).mp4",
        nextUrl: "/ToiletingSkills/Screen3"
    });
</script>