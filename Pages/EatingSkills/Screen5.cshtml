@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>After Eating</h1>

        <div class="video-wrapper">

            <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/EatingSkills/Screen5/0115 (12).mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Leave the table dirty and walk away
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Clean up your plate, throw trash, and wipe the table
                    </button>
                </div>
            </div>

        </div>

        <!-- BACK / UNDO BUTTON -->
        <button class="back-btn" id="backBtn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/EatingSkills/Screen5/0115 (12).mp4",
        correctVideo: "/EatingSkills/Screen5/0115 (13).mp4",
        wrongVideo: "/EatingSkills/Screen5/0115 (14).mp4",
        nextUrl: "/Play"
    });
</script>