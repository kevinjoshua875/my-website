@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>Talking While Eating</h1>

        <div class="video-wrapper">

                        <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/EatingSkills/Screen3/0115 (5).mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <!-- BOTTOM INSIDE VIDEO CHOICES -->
            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Chew your food quietly and then talk
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Talk and laugh with food in your mouth
                    </button>
                </div>
            </div>

        </div>

        <!-- BACK / UNDO BUTTON -->
        <button class="back-btn" id="backBtn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/EatingSkills/Screen3/0115 (5).mp4",
        correctVideo: "/EatingSkills/Screen3/0115 (6).mp4",
        wrongVideo: "/EatingSkills/Screen3/0115 (7).mp4",
        nextUrl: "/EatingSkills/Screen4"
    });
</script>
