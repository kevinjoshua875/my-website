@page

<style>
    @@font-face {
        font-family: "MelonPop";
        src: url("/fonts/Melon Pop.otf") format("opentype"), url("/fonts/Melon Pop.ttf") format("truetype");
        font-weight: normal;
        font-style: normal;
    }

    body {
        margin: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)), url('/images/background.png') no-repeat center center fixed;
        background-size: cover;
        color: whitesmoke;
    }

    .credits-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
        padding: 40px 20px;
        gap: 30px;
        text-align: center;
    }

    h1 {
        font-size: 2.8rem;
        letter-spacing: 6px;
        margin-bottom: 15px;
        text-transform: uppercase;
        color: #fde047;
        font-family: "MelonPop", "Segoe UI", Arial, sans-serif;
        text-shadow: 0 2px 4px rgba(0,0,0,0.7), 0 0 12px rgba(250, 204, 21, 0.7);
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 22px;
        max-width: 950px;
        width: 100%;
    }

    .credit-card {
        background: rgba(255, 255, 255, 0.18);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(255,255,255,0.2);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        animation: popIn 0.6s ease forwards;
    }

        .credit-card:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
        }

    .credits-title {
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 12px;
        color: #fde047;
        font-size: 0.95rem;
    }

    .credit-card div:not(.credits-title) {
        font-size: 0.95rem;
        line-height: 1.6;
        opacity: 0.95;
    }

    .menu-button {
        font-family: "MelonPop", "Segoe UI", Arial, sans-serif;
        margin-top: 35px;
        width: 220px;
        padding: 14px;
        font-size: 1.05rem;
        font-weight: bold;
        letter-spacing: 1px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        background: linear-gradient(135deg, #facc15, #eab308);
        color: #1f2933;
        box-shadow: 0 6px 0 #ca8a04, 0 10px 20px rgba(0,0,0,0.4);
        transition: transform 0.15s, box-shadow 0.15s;
    }

        .menu-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 0 #ca8a04, 0 14px 25px rgba(0,0,0,0.45);
        }

        .menu-button:active {
            transform: translateY(2px);
            box-shadow: 0 3px 0 #ca8a04, 0 6px 12px rgba(0,0,0,0.3);
        }

    @@keyframes popIn {
        from {
            opacity: 0;
            transform: scale(0.9);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="credits-container">
    <h1>CREDITS</h1>

    <div class="cards">
        <div class="credit-card">
            <div class="credits-title">Game Design</div>
            <div>Yzabella M. Calpe</div>
        </div>

        <div class="credit-card">
            <div class="credits-title">Character Designer</div>
            <div>Bettina Gabrielle M. Escosa</div>
        </div>

        <div class="credit-card">
            <div class="credits-title">Voice Actors</div>
            <div>🎤 James Cedric B. Bron</div>
            <div>🎤 Yzabella M. Calpe</div>
            <div>🎤 John Cedric P. Dizon</div>
            <div>🎤 Jubigail Alouibel E. Daclan</div>
            <div>🎤 Bettina Gabrielle M. Escosa</div>
        </div>

        <div class="credit-card">
            <div class="credits-title">Script Writers</div>
            <div>✍️ James Cedric B. Bron</div>
            <div>✍️ Yzabella M. Calpe</div>
        </div>

        <div class="credit-card">
            <div class="credits-title">Video Editor</div>
            <div>🎬 John Cedric P. Dizon</div>
        </div>

        <div class="credit-card">
            <div class="credits-title">Coloring Artists</div>
            <div>🎨 James Cedric B. Bron</div>
            <div>🎨 Yzabella M. Calpe</div>
            <div>🎨 John Cedric P. Dizon</div>
            <div>🎨 Jubigail Alouibel E. Daclan</div>
            <div>🎨 Bettina Gabrielle M. Escosa</div>
        </div>
    </div>

    <p style="opacity:0.85; font-size:0.95rem;">
        Thank you for playing 💛
        This interactive game was made with creativity and care.
    </p>

    <button class="menu-button" onclick="playClickAndBack()">BACK</button>
</div>

<script>
    function playClickAndBack() {
        const sound = document.getElementById("clickSound");

        if (sound) {
            sound.currentTime = 0;
            sound.play();
        }

        setTimeout(() => {
            history.back();
        }, 150);
    }
</script>
