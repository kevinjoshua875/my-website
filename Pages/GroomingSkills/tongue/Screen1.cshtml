@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>Morning Greeting – At School Gate</h1>

        <div class="video-wrapper">

            <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>
v
            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/GroomingSkills/tongue/Screen1/0111 (45).mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <!-- BOTTOM INSIDE VIDEO CHOICES -->
            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Say “Good morning!” clearly with a smile
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Stay quiet and look down
                    </button>
                </div>
            </div>

        </div>

        <!-- BACK / UNDO BUTTON -->
        <button class="back-btn" id="backBtn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/GroomingSkills/tongue/Screen1/0111 (45).mp4",
        correctVideo: "/GroomingSkills/tongue/Screen1/0111 (48).mp4",
        wrongVideo: "/GroomingSkills/tongue/Screen1/0111 (47).mp4",
        nextUrl: "/GroomingSkills/tongue/Screen2"
    });
</script>
