@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>Art Class</h1>

        <div class="video-wrapper">

            <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/GroomingSkills/hair (girls/Screen4/0112 (13).mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <!-- BOTTOM INSIDE VIDEO CHOICES -->
            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Let your hair hang close to your work
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Keep your hair tied or clipped away.
                    </button>
                </div>
            </div>

        </div>

        <!-- BACK / UNDO BUTTON -->
        <button class="back-btn" id="backBtn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/GroomingSkills/hair (girls)/Screen4/0112 (13).mp4",
        correctVideo: "/GroomingSkills/hair (girls)/Screen4/0112 (14).mp4",
        wrongVideo: "/GroomingSkills/hair (girls)/Screen4/0112 (15).mp4",
        nextUrl: "/GroomingSkills/hair (girls)/Screen5"
    });
</script>
