@page

<!-- 🔊 CLICK SOUND -->
<audio id="clickSound" src="/sounds/click.mp3" preload="auto"></audio>

<div class="center-page">
    <div class="menu-card">

        <h1>Walking to School</h1>

        <div class="video-wrapper">

                        <!-- 🔥 SCREEN FLASH OVERLAY -->
            <div id="screenFlash" class="screen-flash"></div>

            @*<video id="lessonVideo" muted playsinline controls> *@
            <video id="lessonVideo" controls>
                <source src="/GroomingSkills/eyes/Screen2/intro.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>

            <!-- BOTTOM INSIDE VIDEO CHOICES -->
            <div class="choices-overlay" id="choices">
                <div class="choices-row">
                    <button class="choice-btn" onclick="selectAnswer(false)">
                        Keep looking up
                    </button>

                    <button class="choice-btn" onclick="selectAnswer(true)">
                        Look away and cover your eyes with a cap
                    </button>
                </div>
            </div>

        </div>

        <!-- BACK / UNDO BUTTON -->
        <button class="back-btn" id="backBtn" onclick="handleBack()">
            ⬅ BACK
        </button>

    </div>
</div>

<script src="/js/video-flow.js"></script>

<script>
    initVideo({
        mainVideo: "/GroomingSkills/eyes/Screen2/intro.mp4",
        correctVideo: "/GroomingSkills/eyes/Screen2/choiceb.mp4",
        wrongVideo: "/GroomingSkills/eyes/Screen2/choicea.mp4",
        nextUrl: "/GroomingSkills/eyes/Screen3"
    });
</script>
